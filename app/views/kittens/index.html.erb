<h1>All Kittens</h1>
<%= link_to "New Kitten", new_kitten_path %>
<ul>
  <% @kittens.each do |kitten| %>
    <li>
      <%= link_to kitten.name, kitten_path(kitten) %>
      (<%= link_to "Edit", edit_kitten_path(kitten) %> |
       <%= link_to "Delete", kitten_path(kitten), method: :delete, data: { confirm: "Are you sure?" } %>)
    </li>
  <% end %>
</ul>
